// Prisma schema — User / Role / Permission (RBAC) + Configuration entities
// Reference fields lifted from Tax Lot Manager reference (Configuration tab).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Users (extended for User Management screens)
// ─────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  fullName     String?
  employeeId   String?  @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  modules      String[]   @default([])
  isActive     Boolean  @default(true)
  createdBy    String?

  roles            UserRole[]
  refreshTokens    RefreshToken[]
  fundAllocations  UserFundAllocation[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([username])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Roles & Permissions
// ─────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  users       UserRole[]
  permissions RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique           // e.g. "fund:write"
  description String?

  roles       RolePermission[]
  createdAt   DateTime @default(now())
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ═════════════════════════════════════════════════════════════
// CONFIGURATION ENTITIES
// ═════════════════════════════════════════════════════════════

// ── Fund Detail ──
enum RankingMethod {
  FIFO
  LIFO
  MFIFO
}

model Fund {
  id                String         @id @default(cuid())
  amcName           String
  fundName          String         @unique
  reportingCurrency String         @default("USD")
  rankingMethod     RankingMethod  @default(FIFO)

  custodians        Custodian[]
  userAllocations   UserFundAllocation[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// ── Custodian (per fund) ──
model Custodian {
  id                String   @id @default(cuid())
  fund              Fund?    @relation(fields: [fundId], references: [id], onDelete: SetNull)
  fundId            String?
  fundName          String   // denormalised label for display
  custodianName     String
  accountNumber     String
  reportingCurrency String   @default("USD")
  // Secrets — store ciphertext or hash in production. For demo, we keep as-is.
  apiKey            String?
  secretKey         String?
  passphrase        String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([fundId])
  @@index([accountNumber])
}

// ── Asset Class ──
enum PrimaryAssetClass {
  EQUITIES
  FUTURES
  OPTIONS
  CRYPTOCURRENCIES
  FIXED_INCOME
}

model AssetClass {
  id              String             @id @default(cuid())
  primary         PrimaryAssetClass
  secondary       String
  valuationSource String

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([primary, secondary])
}

// ── Pre Define (lookup values) ──
model PreDefine {
  id          String   @id @default(cuid())
  category    String   // e.g. "Trade Type"
  code        String   // e.g. "TRD-001"
  label       String
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, code])
}

// ── Chart of Accounts ──
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model ChartOfAccount {
  id          String      @id @default(cuid())
  code        String      @unique // e.g. "1000"
  name        String
  type        AccountType
  parentCode  String?
  currency    String      @default("USD")
  description String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ── Junction: which user is allocated to which fund ──
model UserFundAllocation {
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  fund        Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  fundId      String
  assignedAt  DateTime @default(now())

  @@id([userId, fundId])
  @@index([fundId])
}
