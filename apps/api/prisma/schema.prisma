// Prisma schema — User / Role / Permission (RBAC) + Configuration entities
// Reference fields lifted from Tax Lot Manager reference (Configuration tab).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Users (extended for User Management screens)
// ─────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  fullName     String?
  employeeId   String?  @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  modules      String[]   @default([])
  isActive     Boolean  @default(true)
  createdBy    String?

  roles            UserRole[]
  refreshTokens    RefreshToken[]
  fundAllocations  UserFundAllocation[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([username])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Roles & Permissions
// ─────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  users       UserRole[]
  permissions RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique           // e.g. "fund:write"
  description String?

  roles       RolePermission[]
  createdAt   DateTime @default(now())
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ═════════════════════════════════════════════════════════════
// CONFIGURATION ENTITIES
// ═════════════════════════════════════════════════════════════

// ── Fund Detail ──
enum RankingMethod {
  FIFO
  LIFO
  MFIFO
}

model Fund {
  id                String         @id @default(cuid())
  amcName           String
  fundName          String         @unique
  reportingCurrency String         @default("USD")
  rankingMethod     RankingMethod  @default(FIFO)

  custodians        Custodian[]
  userAllocations   UserFundAllocation[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// ── Custodian (per fund) ──
model Custodian {
  id                String   @id @default(cuid())
  fund              Fund?    @relation(fields: [fundId], references: [id], onDelete: SetNull)
  fundId            String?
  fundName          String   // denormalised label for display
  custodianName     String
  accountNumber     String
  reportingCurrency String   @default("USD")
  // Secrets — store ciphertext or hash in production. For demo, we keep as-is.
  apiKey            String?
  secretKey         String?
  passphrase        String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([fundId])
  @@index([accountNumber])
}

// ── Asset Class ──
enum PrimaryAssetClass {
  EQUITIES
  FUTURES
  OPTIONS
  CRYPTOCURRENCIES
  FIXED_INCOME
}

model AssetClass {
  id              String             @id @default(cuid())
  primary         PrimaryAssetClass
  secondary       String
  valuationSource String

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([primary, secondary])
}

// ── Pre Define (lookup values) ──
model PreDefine {
  id          String   @id @default(cuid())
  category    String   // e.g. "Trade Type"
  code        String   // e.g. "TRD-001"
  label       String
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, code])
}

// ── Chart of Accounts ──
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model ChartOfAccount {
  id          String      @id @default(cuid())
  code        String      @unique // e.g. "1000"
  name        String
  type        AccountType
  parentCode  String?
  currency    String      @default("USD")
  description String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ── Junction: which user is allocated to which fund ──
model UserFundAllocation {
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  fund        Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  fundId      String
  assignedAt  DateTime @default(now())

  @@id([userId, fundId])
  @@index([fundId])
}

// ═════════════════════════════════════════════════════════════
// INVESTOR ENTITIES (Investor Management — Basic / KYC / Tax)
// ═════════════════════════════════════════════════════════════

enum InvestorEntityType {
  INDIVIDUAL
  LLC
  CORPORATION
  TRUST
  PARTNERSHIP
}

enum FormStatus {
  SUBMITTED
  PENDING
  NOT_REQUIRED
  EXPIRED
}

enum W8Status {
  W8BEN_SUBMITTED
  W8BENE_SUBMITTED
  PENDING
  NOT_REQUIRED
  EXPIRED
}

enum FatcaClassification {
  US_PERSON
  NON_US_INDIVIDUAL
  PFFI
  NPFFI
  EXEMPT
}

model Investor {
  id           String              @id @default(cuid())
  // Auto-generated business key e.g. "INV-A3F9K2"
  investorId   String              @unique
  fullName     String
  dateOfBirth  DateTime?
  entityType   InvestorEntityType
  // Stored verbatim for demo; in production encrypt or hash partial.
  ssnTin       String?
  email        String              @unique
  phone        String?

  kyc          InvestorKyc?
  tax          InvestorTax?

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([fullName])
}

model InvestorKyc {
  id                String   @id @default(cuid())
  investor          Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  investorId        String   @unique

  primaryAddress    String
  mailingAddress    String?
  cityStateZip      String
  country           String
  citizenship       String
  taxResidency      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model InvestorTax {
  id                   String               @id @default(cuid())
  investor             Investor             @relation(fields: [investorId], references: [id], onDelete: Cascade)
  investorId           String               @unique

  tinSsnEin            String?
  w9Status             FormStatus?
  w8Status             W8Status?
  fatca                FatcaClassification?
  backupWithholding    Boolean              @default(false)

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

// ═════════════════════════════════════════════════════════════
// VALUATION ENTITIES — Securities, Market Prices, Exchange Rates
// ═════════════════════════════════════════════════════════════

enum SecurityType {
  EQUITY
  FUTURE
  OPTION
  CRYPTO
  BOND
  CASH
  OTHER
}

model Security {
  id              String   @id @default(cuid())
  // Internal SM ID (e.g. "SM-000001"); auto-generated
  smId            String   @unique
  type            SecurityType
  ticker          String
  name            String
  assetClass      String   // free-text label (e.g. "Cryptocurrencies")
  exchange        String?
  currency        String   @default("USD")
  multiplier      Decimal  @default(1) @db.Decimal(20, 8)
  valuationSource String?
  valuationSourceId String?

  marketPrices    MarketPrice[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([ticker, currency])
  @@index([ticker])
}

model MarketPrice {
  id           String   @id @default(cuid())
  security     Security? @relation(fields: [securityId], references: [id], onDelete: SetNull)
  securityId   String?

  // Denormalised display fields so a price row doesn't strictly require a Security row
  ticker       String
  name         String
  assetClass   String
  currency     String   @default("USD")

  price        Decimal  @db.Decimal(28, 10)
  priceDate    DateTime
  source       String?
  sourceId     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ticker, priceDate, currency])
  @@index([ticker])
  @@index([priceDate])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  // ISO code e.g. "USD", or crypto "BTC" — quoted against base currency (USD)
  currency     String
  symbol       String?  // optional friendly symbol e.g. "$"
  rate         Decimal  @db.Decimal(28, 10)
  rateDate     DateTime
  source       String?
  sourceId     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([currency, rateDate])
  @@index([currency])
  @@index([rateDate])
}
