{
  "name": "trading-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @app/api prisma:generate",
    "db:migrate": "pnpm --filter @app/api prisma:migrate",
    "db:seed": "pnpm --filter @app/api prisma:seed",
    "db:studio": "pnpm --filter @app/api prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.6",
    "typescript": "^5.4.5",
    "prettier": "^3.3.2"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
